# ── Build output ──────────────────────────────────────────
dist/                 # release bundle (scripts/build-bundle.sh) + cli/dist cross-compiles
/local-search         # dev binary built at repo root
/cli/local-search     # dev binary built in cli/  (does NOT match cli/skilldata/local-search/)
local-search-*        # cross-compiled binaries (…-darwin-arm64, …-linux-amd64, …)
*.exe

# ── Go ────────────────────────────────────────────────────
# NOTE: go.sum IS committed — do not ignore it.
*.o
*.a
*.so
*.test

# ── Node / web ────────────────────────────────────────────
# NOTE: package-lock.json IS committed — build-bundle.sh runs `npm ci`.
node_modules/
web/frontend/dist/
web/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── Agent / tooling scratch (personal, regenerable) ───────
.devlocal/
graphify-out/

# ── Data / caches ─────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
.pytest_cache/
__pycache__/
*.py[cod]

# ── Env ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── OS / IDE ──────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
